# 环境变量模板
#
# 使用方式：复制本文件为 .env.development 或 .env.production，随后仅保留
# 对应环境的配置块。不要在同一个 .env 文件中同时启用两套同名变量；
# dotenv 会采用最后定义的值。

# ================================================================
# 开发环境（.env.development）
# ================================================================
NODE_ENV=development
TRUST_PROXY=false

HOST=127.0.0.1
PORT=3000

DATABASE_PATH=./storage/data/edc.sqlite
UPLOAD_ROOT=./storage/uploads
QUARANTINE_ROOT=./storage/quarantine
EXPORT_ROOT=./storage/exports

SESSION_COOKIE_NAME=edc_session
SESSION_TTL_HOURS=12

# ================================================================
# 生产环境（.env.production）
# 将以下配置块复制到独立的 .env.production 文件中使用。
# 生产部署在反向代理之后时，TRUST_PROXY 应设为 true。
# ================================================================
# NODE_ENV=production
# TRUST_PROXY=true
#
# HOST=0.0.0.0
# PORT=3000
#
# DATABASE_PATH=./storage/data/edc.sqlite
# UPLOAD_ROOT=./storage/uploads
# QUARANTINE_ROOT=./storage/quarantine
# EXPORT_ROOT=./storage/exports
#
# SESSION_COOKIE_NAME=edc_session
# SESSION_TTL_HOURS=12
