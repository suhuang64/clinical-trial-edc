{
  "name": "openedc",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node --env-file=.env.development scripts/dev.mjs",
    "dev:web": "npm run dev --workspace @edc/web",
    "dev:api": "npm run dev --workspace @edc/api",
    "start": "node --env-file=.env.production --conditions=production apps/api/dist/server.js",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run test --workspaces --if-present",
    "admin:init": "npm run admin:init --workspace @edc/api --"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@types/node": "latest",
    "eslint": "latest",
    "eslint-plugin-vue": "latest",
    "globals": "latest",
    "prettier": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "vite": "latest",
    "vitest": "latest"
  },
  "allowScripts": {
    "argon2@0.44.0": true,
    "better-sqlite3@12.11.1": true,
    "esbuild@0.28.1": true
  }
}
